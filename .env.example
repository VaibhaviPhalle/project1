# Copy to .env and fill in. NEVER commit .env.
# All keys are optional for offline mode (Ollama). Provide at least one for hosted models.

# ---- LLM providers (free tiers) ----
GROQ_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# ---- Observability (optional) ----
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=auth-rag

# ---- App configuration ----
AUTH_RAG_ENV=local              # local | ci | prod
AUTH_RAG_LOG_LEVEL=INFO         # DEBUG | INFO | WARNING | ERROR
AUTH_RAG_LOG_FORMAT=console     # console | json

# ---- Model selection ----
AUTH_RAG_GENERATION_PROVIDER=groq        # groq | google | ollama | openai
AUTH_RAG_GENERATION_MODEL=llama-3.3-70b-versatile
AUTH_RAG_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
AUTH_RAG_RERANKER_MODEL=BAAI/bge-reranker-base

# ---- Paths ----
AUTH_RAG_DATA_DIR=./data
AUTH_RAG_INDEX_DIR=./chroma_db
AUTH_RAG_CACHE_DIR=./.cache
